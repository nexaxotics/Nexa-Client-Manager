# Nexaxotics Backend Environment Variables
# Copy this file to .env and fill in your values

NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexaxotics

# Redis
REDIS_URL=redis://localhost:6379

# JWT - Generate RSA keys with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY=your-base64-encoded-private-key
JWT_PUBLIC_KEY=your-base64-encoded-public-key

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=hello@youragency.com

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=nexaxotics-files
AWS_REGION=us-east-1

# Browserless.io
BROWSERLESS_API_KEY=your-browserless-key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
